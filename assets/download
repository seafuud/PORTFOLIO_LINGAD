  padding: 1rem 2rem;
  box-shadow: 0 5px 20px rgba(0,0,0,0.7);
  z-index: 100;
}

/* -------------------- HERO -------------------- */
.hero {
  height: 85vh;
  display: flex;
  justify-content: center;
  align-items: center;
  text-align: center;
  flex-direction: column;
  background: linear-gradient(160deg, #0a0d1a, #11172b);
}

.profile-img {
  width: 200px;
  height: 200px;
  border-radius: 50%;
  border: 4px solid #00f0ff;
  object-fit: cover;
  box-shadow: 0 0 20px #00f0ff50;
  margin-bottom: 20px;
  transition: transform 0.4s ease;
}

.profile-img:hover {
  transform: scale(1.05) rotate(3deg);
}

.hero h1 {
  font-size: clamp(2rem, 5vw, 3rem);
  margin-bottom: 10px;
  color: #00f0ff;
  text-shadow: 0 0 15px #00f0ff50;
}

.hero p {
  font-size: 1.2rem;
  color: #a0c4ff;
}

/* -------------------- SECTION CONTAINERS -------------------- */
section {
  padding: 60px 0;
  position: relative;
}

.bg-container {
  background: rgba(15,26,46,0.85);
  backdrop-filter: blur(10px);
  padding: 30px;
  border-radius: 16px;
  box-shadow: 0 5px 20px rgba(0,0,0,0.5);
  margin-bottom: 30px;
  transition: transform 0.4s ease, box-shadow 0.4s ease;
}

.bg-container:hover {
  transform: translateY(-6px);
  box-shadow: 0 15px 35px rgba(255,60,143,0.4);
}

/* -------------------- SECTION TITLES -------------------- */
.section-title {
  font-size: clamp(1.8rem, 4vw, 2.2rem);
  font-weight: 700;
  color: #00f0ff;
  margin-bottom: 40px;
  text-align: center; /* only titles are centered */
  position: relative;
}
.section-title::after {
  content: "";
  width: 50px;
  height: 3px;
  background: #ff3c8f;
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  bottom: -10px;
  border-radius: 2px;
}

/* -------------------- GRID BACKGROUND SECTIONS -------------------- */
#background, #education, #projects {
  background-color: #0e1425;
  background-image:
    linear-gradient(to right, rgba(255,255,255,0.05) 1px, transparent 1px),
    linear-gradient(to bottom, rgba(255,255,255,0.05) 1px, transparent 1px);
  background-size: 40px 40px;
  background-position: 0 0;
  color: #e0e7ff;
  padding-top: 60px;
  padding-bottom: 60px;
}

/* -------------------- SUMMARY -------------------- */
.summary-text {
  font-size: 0.95rem;
  line-height: 1.6;
  color: #bfdbfe;
  background: rgba(59,130,246,0.1);
  padding: 15px 20px;
  border-radius: 10px;
  box-shadow: 0 4px 20px rgba(0,0,0,0.3);
  transition: all 0.8s ease;
  opacity: 0;
  transform: translateY(20px);
}

/* -------------------- SKILLS -------------------- */
.skill-group span {
  display: inline-block;
  padding: 6px 14px;
  margin: 5px;
  font-size: 0.8rem;
  background: rgba(0,240,255,0.15);
  color: #c0d8ff;
  border-radius: 8px;
  transition: 0.3s;
}
.skill-group span:hover {
  background: #00f0ff;
  color: #111;
}

/* -------------------- EDUCATION -------------------- */
.education-item {
  transition: all 0.6s ease;
}
.education-item:hover {
  transform: translateY(-6px);
  box-shadow: 0 15px 35px rgba(255,60,143,0.4);
}
.education-item p {
  margin: 5px 0;
  font-weight: 500;
}

/* -------------------- PROJECTS -------------------- */
#projects .cards {
